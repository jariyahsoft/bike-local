# Copy values into environment-specific secret/config stores. Do not put real
# secrets in this file and do not commit generated .env files.
BIKE_LOCAL_ENV=dev
FIREBASE_PROJECT_ID=bike-local-dev
FIREBASE_STORAGE_BUCKET=bike-local-dev.appspot.com
API_BASE_URL=http://127.0.0.1:5001/bike-local-dev/us-central1/api
PUBLIC_WEB_BASE_URL=http://localhost:3000
PAYMENT_PROVIDER=sandbox
PAYMENT_WEBHOOK_SECRET_SECRET_NAME=payment-webhook-secret
QR_TOKEN_SIGNING_SECRET_NAME=qr-token-signing-secret
FCM_CREDENTIALS_SECRET_NAME=fcm-credentials
APP_CHECK_DEBUG_TOKEN_SECRET_NAME=app-check-debug-token
SETTLEMENT_PLATFORM_COMMISSION_BPS=1000
SETTLEMENT_PAYMENT_FEE_BPS=300
SENTRY_DSN_SECRET_NAME=sentry-dsn
ENABLE_ANALYTICS=false
ENABLE_CRASHLYTICS=false
